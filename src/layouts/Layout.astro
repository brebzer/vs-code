---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <title>{title ?? 'Hexus'}</title>

    
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap" rel="stylesheet">

  </head>

  <body>
      <h1>
  <a href="/" class="title-link">The Legacies of Hexus</a>
</h1>

    <nav class="menu" role="navigation" aria-label="Main navigation">
      <a href="/characters">Characters</a>
      <a href="/locations">Locations</a>
      <a href="races">Races</a>
      <a href="/timeline">Timeline</a>
    </nav>

    <slot />
  </body>
</html>

<style>
body {
  background-color: #2f3030;
  margin: 0;
  font-family: Arial, sans-serif;
  color: whitesmoke;
}

h1 {
  text-align: center;
  margin: 20px;
  padding: 20px;
  border-radius: 10px;
  background-image: linear-gradient(to right, #5f5e65, #2f3030);
  color: white;
}

/* FIXED: removed extra dot */
.menu {
  display: flex;
  justify-content: center;
  gap: 40px;
  font-size: 20px;
  margin: 20px;
  padding: 20px;
  border-radius: 10px;
  background-image: linear-gradient(to right, #5f5e65, #2f3030);
}

/* Accessible menu item styles */
.menu a {
  color: white;
  text-decoration: none;
  padding: 8px 12px;
  border-radius: 6px;
  transition: background 0.3s, box-shadow 0.3s;
}

.menu a:hover,
.menu a:focus {
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 3px rgba(255, 126, 95, 0.15);
}

.menu a:focus-visible {
  outline: 2px solid #ff7e5f;
  outline-offset: 2px;
}

@media (max-width: 768px) {
  .menu {
    flex-direction: column;
    align-items: center;
    gap: 15px;
  }
}

body h1, .menu a {
  font-family: 'Cinzel', serif;
}
.title-link {
  color: white;
  text-decoration: none;
}
</style>
