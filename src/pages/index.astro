---
import Layout from "../layouts/Layout.astro";
import Footer from "../layouts/Footer.astro";
import CoverPlaceholder from '../src/assets/cover_placeholder.png';
---

<link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&display=swap" rel="stylesheet">
<style is:global>
  body {
    font-family: 'Cinzel', serif;
  }
</style>

<Layout title="Homepage">
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #2f3030;
    }

    header {
      background-image: linear-gradient(to right, #5f5e65, #2f3030);
      text-align: center;
      padding: 10px;
      font-size: 25px;
      color: white;
    }

    header a {
      color: white;
      text-decoration: none;
    }

    .menu {
      display: flex;
      justify-content: center;
      gap: 40px;
      font-size: 20px;
      margin: 20px 20px 40px;
      padding: 20px;
      border-radius: 10px;
      background-image: linear-gradient(to right, #5f5e65, #2f3030);
    }

    .menu a {
      color: white;
      text-decoration: none;
    }

    /* ✅ Modern section layout */
    section {
      display: flex;
      margin: 0 20px 40px;
    }

    nav {
      width: 30%;
      background: #2c2a2a;
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ✅ Makes image fully fit */
    nav img {
      width: 100%;
      height: auto;
      border-radius: 10px;
      object-fit: cover;
    }

    article {
      width: 70%;
      padding: 20px;
      background-color: #c6c6c7;
      color: #2f3030;
    }

    footer {
      background: linear-gradient(to right, #5f5e65, #2f3030);
      padding: 10px;
      text-align: center;
      color: rgb(244, 234, 234);
      border-radius: 10px;
    }
  </style>

  <section>
    <nav>
      <img src="https://raw.githubusercontent.com/brebzer/vs-code/refs/heads/main/src/assets/images/cover_placeholder.png" alt="Book Cover" />
    </nav>

    <article>
      <h1>Welcome to World of Hexus</h1>

      <p>
        The legacys of Hexus is an upcoming fantasy series set in a magical and immersive world.
        Explore the locations, characters, and races of this unique setting.
      </p>

      <p>
        Follow the journey of "The Sea Runner" William Anron as he is drawn into a conflict
        that will change the fate of Hexus forever.
        All the while his son Borlock is caught between two worlds, and must find his own path.
      </p>

      <p>
        Discover the rich lore and intricate history that will lead to the beginning of our story.
      </p>

      <p>
        Stay tuned for more updates on Book 1 "The Sea Runner's Call"!
      </p>
    </article>
  </section>

  <Footer />
</Layout>
