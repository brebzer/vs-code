---
import Layout from "../layouts/Layout.astro";
import Footer from "../layouts/Footer.astro";
---

<Layout title="Characters">

    <style>
body {
  background-color: #2f3030;
  margin: 0;
  font-family: Arial, sans-serif;
  color: whitesmoke;
}
footer {
    text-align: center;
    margin-top: 50px;
    color: whitesmoke;
}
h1 {
  text-align: center;
  margin: 20px;
  padding: 20px;
  border-radius: 10px;
  background-image: linear-gradient(to right, #5f5e65, #2f3030);
}

h2, p {
  text-align: center;
  margin: 20px;
  padding: 20px;
  border-radius: 10px;
  background-image: linear-gradient(to right, #5f5e65, #2f3030);
  margin-left: 30%;
  margin-right: 30%;
}



/* ---------- GRID ---------- */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  justify-content: center;
  padding: 20px;
  margin-left: 10%;
  margin-right: 10%;
}

/* ---------- IMAGE CARD ---------- */
.container {
  position: relative;
  width: 250px;
  border-radius: 10px;
  overflow: hidden;
}

.image {
  width: 100%;
  height: auto;
  display: block;
}

.overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(47, 48, 48, 0.9);
  opacity: 0;
  transition: 0.4s ease;
}

.container:hover .overlay {
  opacity: 1;
}

.text {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

    </style>
  <h1>Characters</h1>

<p>Book 1 Main Characters</p>
<div class="grid">  


  <div class="container">
