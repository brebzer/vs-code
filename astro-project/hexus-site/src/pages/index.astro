---
import Layout from "../layouts/Layout.astro";
import Footer from "../layouts/Footer.astro";
---

<Layout title="Homepage">
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #2f3030;
    }

    header {
      background-image: linear-gradient(to right, #5f5e65, #2f3030);
      text-align: center;
      padding: 2px;
      font-size: 25px;
      color: white;
    }

    nav {
      float: left;
      width: 30%;
      height: 300px;
      background: #fff;
      padding: 20px;
    }

    nav ul {
      list-style-type: none;
      padding: 0;
    }

    article {
      float: left;
      padding: 20px;
      width: 70%;
      background-color: #f1f1f1;
      height: 300px;
    }

    section::after {
      content: "";
      display: table;
      clear: both;
    }

    .menu {
      display: flex;
      justify-content: center;
      gap: 40px;
      margin-bottom: 40px;
      font-size: 20px;
      margin: 20px;
      padding: 20px;
      border-radius: 10px;
      background-image: linear-gradient(to right, #5f5e65, #2f3030);
    }

    .menu a {
      color: white;
      text-decoration: none;
    }

    header a {
      color: white;
      text-decoration: none;
    }
  </style>

  
  <section>
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/learn">Learn HTML</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/locations">Locations</a></li>
        <li><a href="/characters">Characters</a></li>
      </ul>
    </nav>

    <article>
      <h1>Welcome to World of Hexus</h1>
      <p>
        The legacys of Hexus is an upcoming fantasy series set in a magical and
        immersive world. Explore the locations, characters, and races of this
        unique setting.
      </p>
      <p>
        Discover the rich lore and intricate history that will lead to the
        beginning of our story.
      </p>
      <p>
        Stay tuned for more updates on Book 1 "The Sea Runner's Call"!
      </p>
    </article>
  </section>

  <Footer />
</Layout>